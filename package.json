{
  "name": "arduino-block-app",
  "version": "0.1.0",
  "description": "A visual block-based programming tool for Arduino using Blockly",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "npm run build && electron .",
    "dev": "concurrently \"tsc --watch\" \"nodemon --watch dist/main/main.js --exec electron .\"",
    "clean": "rimraf dist"
  },
  "keywords": [
    "arduino",
    "blockly",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "nodemon": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "blockly": "^11.0.0",
    "electron": "^31.0.0"
  },
  "allowScripts": {
    "electron@31.7.7": true
  }
}
